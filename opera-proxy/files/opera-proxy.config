config instance 'default'
    option enabled '1'
    option args '--bind-address 127.0.0.1:18080'

config instance 'Americas'
    option enabled '0'
    option args '--bind-address 127.0.0.1:18081 -country AM -socks-mode'

config instance 'Asia'
    option enabled '0'
    option args '--bind-address 127.0.0.1:18082 -country AS -socks-mode'
